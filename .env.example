# Configuration Example
# Copy this file to .env and fill in your values

# Workspace Directory
WORKSPACE="${HOME}/.openclaw/workspace-video-learner"

# Feishu Configuration
FEISHU_SPACE_ID="your_space_id_here"
FEISHU_PARENT_TOKEN="your_parent_node_token_here"

# ASR Configuration
# ASR 引擎选择：aliyun（阿里云 ASR，推荐）或 whisper（本地 Whisper）
ASR_ENGINE="aliyun"

# 阿里云 ASR API Key（从阿里云控制台获取）
ALIYUN_ASR_API_KEY="your_aliyun_api_key_here"

# 阿里云 ASR 模型（默认：fun-asr-mtl）
# 可选模型：fun-asr-mtl, paraformer-realtime-8k-v1, paraformer-realtime-16k-v1
ASR_MODEL="fun-asr-mtl"

# ASR 超时时间（秒，默认：60）
ASR_TIMEOUT="60"

# Whisper 模型（仅当 ASR_ENGINE=whisper 时使用）
# Options: tiny, base, small, medium, large
WHISPER_MODEL="base"

# Optional: Bilibili Cookies Path
BILIBILI_COOKIES="${WORKSPACE}/cookies/bilibili_cookies.txt"

# Note Generation Configuration
# 笔记生成引擎：glm（GLM-4-Flash，推荐）或 smart（词频提取）
NOTE_ENGINE="glm"

# GLM-4-Flash API Key（从智谱 AI 控制台获取）
# 获取地址：https://open.bigmodel.cn/
GLM_API_KEY="your_glm_api_key_here"
# 笔记生成引擎：glm（GLM-4-Flash，推荐）或 smart（词频提取）
NOTE_ENGINE="glm"

# GLM-4-Flash API Key（从智谱 AI 控制台获取）
# 获取地址：https://open.bigmodel.cn/
GLM_API_KEY="your_glm_api_key_here"
