# Configuration Example
# Copy this file to .env and fill in your values

# Workspace Directory
WORKSPACE="${HOME}/.openclaw/workspace-video-learner"

# Feishu Configuration
FEISHU_SPACE_ID="your_space_id_here"
FEISHU_PARENT_TOKEN="your_parent_node_token_here"

# Optional: Custom Whisper Model
WHISPER_MODEL="base"  # Options: tiny, base, small, medium, large

# Optional: Bilibili Cookies Path
BILIBILI_COOKIES="${WORKSPACE}/cookies/bilibili_cookies.txt"
