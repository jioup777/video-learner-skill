# Video Learner 配置文件示例
# 复制此文件为 .env 并填写实际值

# ===== 必需配置 =====

# GLM API Key (用于笔记生成)
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key

# 阿里云 DashScope ASR API Key (用于语音转录)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key
ALIYUN_ASR_API_KEY=your_dashscope_api_key

# 飞书配置 (上传笔记)
FEISHU_SPACE_ID=your_feishu_space_id
FEISHU_PARENT_TOKEN=your_feishu_parent_token

# ===== 可选配置 =====

# 代理配置 (海外服务器无需配置)
# 格式: http://127.0.0.1:7897 或 socks5://127.0.0.1:1080
# VIDEO_LEARNER_PROXY=

# 代理配置 (中国大陆网络环境可能需要)
# 海外服务器请留空或删除此配置
# VIDEO_LEARNER_PROXY=http://127.0.0.1:7897

# 工作目录 (默认值)
WORKSPACE=~/.openclaw/workspace-video-learner

# 阿里云 Access Key ID (如使用签名方式)
# ALIYUN_ACCESS_KEY_ID=

# 阿里云 Access Key Secret (如使用签名方式)
# ALIYUN_ACCESS_KEY_SECRET=
